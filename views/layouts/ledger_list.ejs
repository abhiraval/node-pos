<%- include('header') %>
<div class="container-fluid" style="padding-top: 100px;">
  <main class="col-md-10 ms-sm-auto px-md-4">
    <h2 class="mb-4">Financial Ledger Accounts</h2>
    
    <div class="card shadow-sm">
      <div class="card-body">
        <table class="table table-hover">
          <thead class="table-light">
            <tr>
              <th>Account Name</th>
              <th>Type</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% accounts.forEach(acc => { %>
              <tr>
                <td><strong><%= acc.name %></strong></td>
                <td><span class="badge <%= acc.type === 'customer' ? 'bg-primary' : 'bg-info' %>"><%= acc.type %></span></td>
                <td>
                  <a href="/ledger/<%= acc.type %>/<%= acc.id %>" class="btn btn-sm btn-outline-dark">
                    View Full Statement
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
<%- include('footer') %>