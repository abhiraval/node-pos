<%- include('header') %>

<div class="container-fluid" style="padding-top: 100px;">
    <main class="col-md-10 ms-sm-auto px-md-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0 fw-bold text-dark">Account Statement</h2>
                <p class="text-muted">
                    <span class="badge bg-primary text-uppercase"><%= type %></span> 
                    <span class="ms-2">ID: #<%= id %></span>
                </p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary shadow-sm" onclick="openPaymentModal()">
                    <i class="bi bi-plus-lg"></i> Record Transaction
                </button>
                <a href="/ledger-list" class="btn btn-outline-secondary shadow-sm">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 border-start border-danger border-4">
                    <div class="text-muted small fw-bold">TOTAL DEBIT (+)</div>
                    <div class="h3 mb-0 text-danger">₹ <%= parseFloat(totalDebit).toFixed(2) %></div>
                    <div class="text-muted x-small">Sales / Charges / Outward</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-3 border-start border-success border-4">
                    <div class="text-muted small fw-bold">TOTAL CREDIT (-)</div>
                    <div class="h3 mb-0 text-success">₹ <%= parseFloat(totalCredit).toFixed(2) %></div>
                    <div class="text-muted x-small">Payments / Returns / Inward</div>
                </div>
            </div>
            <div class="col-md-4">
                <% let balance = totalDebit - totalCredit; %>
                <div class="card border-0 shadow-sm p-3 border-start border-primary border-4 <%= balance < 0 ? 'bg-success-subtle' : 'bg-warning-subtle' %>">
                    <div class="text-muted small fw-bold">NET BALANCE</div>
                    <div class="h3 mb-0 text-primary">₹ <%= Math.abs(balance).toFixed(2) %></div>
                    <div class="fw-bold fs-6 <%= balance < 0 ? 'text-success' : 'text-danger' %>">
                        <%= balance < 0 ? '● ADVANCE / OVERPAID' : '● TOTAL DUE / OWED' %> 
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2"></i>Transaction History</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Date & Time</th>
                                <th>Description / Reference</th>
                                <th>Method</th>
                                <th class="text-danger">Debit (+)</th>
                                <th class="text-success">Credit (-)</th>
                                <th class="text-end pe-4">Running Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (transactions.length > 0) { %>
                                <% transactions.forEach(t => { %>
                                    <tr>
                                        <td class="ps-4 small text-muted">
                                            <%= new Date(t.created_at).toLocaleString('en-IN') %>
                                        </td>
                                        <td>
                                            <div class="fw-bold"><%= t.description %></div>
                                            <% if(t.reference_id) { %>
                                                <small class="text-primary text-decoration-none">Ref: #<%= t.reference_id %></small>
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill bg-light text-dark border">
                                                <%= t.payment_method || 'N/A' %>
                                            </span>
                                        </td>
                                        <td class="text-danger fw-semibold">
                                            <%= t.transaction_type === 'debit' ? '₹ ' + parseFloat(t.amount).toFixed(2) : '-' %>
                                        </td>
                                        <td class="text-success fw-semibold">
                                            <%= t.transaction_type === 'credit' ? '₹ ' + parseFloat(t.amount).toFixed(2) : '-' %>
                                        </td>
                                        <td class="text-end pe-4 fw-bold">
                                            ₹ <%= parseFloat(t.running_balance).toFixed(2) %>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-5 text-muted">
                                        <i class="bi bi-folder2-open display-4 d-block mb-2"></i>
                                        No transactions recorded yet.
                                    </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">Add Ledger Entry</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="paymentForm">
                <div class="modal-body p-4">
                    <input type="hidden" name="entity_type" value="<%= type %>">
                    <input type="hidden" name="entity_id" value="<%= id %>">
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Transaction Type</label>
                        <select name="transaction_type" class="form-select form-select-lg border-2 border-primary" required>
                            <option value="credit">Payment Received / Money In (Credit -)</option>
                            <option value="debit">New Charge / Money Out (Debit +)</option>
                        </select>
                        <div class="form-text mt-2">
                            Select <strong>Credit</strong> for payments or returns. Select <strong>Debit</strong> for sales or manual charges.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Amount (₹)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light fw-bold">₹</span>
                            <input type="number" name="amount" class="form-control form-control-lg" placeholder="0.00" required step="0.01">
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Payment Method</label>
                            <select name="payment_method" class="form-select">
                                <option value="Cash">Cash</option>
                                <option value="UPI">UPI / GPay</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                                <option value="Card">Card</option>
                                <option value="Adjustment">Adjustment</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Reference ID</label>
                            <input type="text" name="reference_id" class="form-control" placeholder="Optional">
                        </div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-bold">Description / Notes</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="e.g., Monthly bill settlement"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Save Transaction</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Handle Form Submission
    document.getElementById('paymentForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        try {
            const res = await fetch('/ledger/add-payment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await res.json();
            
            if (result.success) {
                location.reload();
            } else {
                alert("Error: " + (result.error || "Payment failed to save."));
            }
        } catch (err) {
            console.error(err);
            alert("Network error occurred.");
        }
    });

    // Function to trigger modal
    function openPaymentModal() {
        const modalEl = document.getElementById('paymentModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
    }
</script>

<%- include('footer') %>