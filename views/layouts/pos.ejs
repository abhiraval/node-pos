<%- include('header') %>

<div class="container-fluid">
  <div class="row">
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="padding-top: 50px;">
      
      <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h2 class="h2">POS Billing</h2>
      </div>

 <div class="row">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Products</h4>
            <input type="text" id="productSearch" class="form-control w-50" placeholder="Search product...">
        </div>
        <div class="row" id="productList">
            <% products.forEach(p => { %>
                <div class="col-sm-6 col-lg-4 mb-3 product-item" data-name="<%= p.name.toLowerCase() %>">
                    <div class="card h-100 p-2 shadow-sm">
                        <div class="d-flex justify-content-between align-items-start">
                            <b style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%;"><%= p.name %></b>
                            <button class="btn btn-sm btn-primary pos-add-to-cart"
                                data-id="<%= p.id %>" 
                                data-name="<%= p.name %>" 
                                data-price="<%= p.price %>">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        <small class="text-muted">₹ <%= p.price %> | Stock: <%= p.stock %></small>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm p-3">
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">Select Customer</h5>
                    <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#newCustomerModal">
                        <i class="bi bi-person-plus"></i>
                    </button>
                </div>
                <select id="customerSelect" class="form-select mb-2">
                    <option value="0">Walk-in Customer</option>
                    <% if (typeof customers !== 'undefined' && customers.length > 0) { %>
                        <% customers.forEach(c => { %>
                            <option value="<%= c.id %>"><%= c.name %> - <%= c.phone %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>

            <h4>Current Cart</h4>
            <div class="table-responsive" style="max-height: 300px;">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Qty</th>
                            <th>Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="cartBody">
                        </tbody>
                </table>
            </div>

            <hr>
            <div class="d-flex justify-content-between align-items-center">
                <h5>Total:</h5>
                <h3 class="text-success">₹ <span id="grandTotal">0</span></h3>
            </div>

            <div class="mb-3">
                <label class="form-label">Payment Method</label>
                <select id="paymentMethod" class="form-select">
                    <option value="Cash">Cash</option>
                    <option value="Card">Credit/Debit Card</option>
                    <option value="UPI">UPI / QR Scan</option>
                </select>
            </div>

            <button class="btn btn-success w-100 mt-3 py-2 fw-bold" id="checkoutBtn">
                Complete Sale (Checkout)
            </button>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="posToast" class="toast align-items-center text-white border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body" id="toastMessage"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>
    </main>
  </div>
</div>

<div id="toastBox" class="position-fixed top-0 end-0 p-3" style="z-index:9999;"></div>
<div class="modal fade" id="newCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form id="quickAddCustomerForm">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>New Customer</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Full Name</label>
                        <input type="text" name="name" class="form-control" placeholder="Enter name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Phone Number</label>
                        <input type="text" name="phone" class="form-control" placeholder="Enter phone" required>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save & Select</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
let cart = [];

// Helper for Notifications
function showNotify(msg, type = 'success') {
    const toastEl = document.getElementById('posToast');
    const toastMsg = document.getElementById('toastMessage');
    toastEl.className = `toast align-items-center text-white border-0 bg-${type === 'success' ? 'success' : 'danger'}`;
    toastMsg.innerText = msg;
    const toast = new bootstrap.Toast(toastEl);
    toast.show();
}

// ✅ Fix 1: Complete Checkout Process
document.getElementById('checkoutBtn').onclick = async function() {
    if (cart.length === 0) return showNotify("Cart is empty!", "danger");

    const btn = this;
    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerText = "Processing...";

    const payload = {
        cart: cart,
        paymentMethod: document.getElementById('paymentMethod').value,
        customer_id: document.getElementById('customerSelect').value
    };

    try {
        const res = await fetch('/pos/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const result = await res.json();

        if (result.success) {
            showNotify("Checkout successful! Redirecting...");
            setTimeout(() => window.location.href = "/invoice/" + result.saleId, 1000);
        } else {
            showNotify(result.error || "Error during checkout", "danger");
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    } catch (err) {
        showNotify("Server connection failed", "danger");
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
};

// Standard Cart Rendering (Maintains your table IDs)
document.addEventListener('click', function (e) {
    const btn = e.target.closest('.pos-add-to-cart');
    if (btn) {
        const id = btn.dataset.id;
        const name = btn.dataset.name;
        const price = parseFloat(btn.dataset.price);

        const item = cart.find(i => i.id === id);
        if (item) item.qty++;
        else cart.push({ id, name, price, qty: 1 });
        
        renderCart();
    }
});

function renderCart() {
    const body = document.getElementById('cartBody');
    body.innerHTML = cart.map((item, idx) => `
        <tr>
            <td>${item.name}</td>
            <td width="60"><input type="number" class="form-control form-control-sm" value="${item.qty}" onchange="updateQty(${idx}, this.value)"></td>
            <td>₹${(item.price * item.qty).toFixed(2)}</td>
            <td><button class="btn btn-sm text-danger" onclick="removeItem(${idx})"><i class="bi bi-x-circle"></i></button></td>
        </tr>
    `).join('');
    
    const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    document.getElementById('grandTotal').innerText = total.toFixed(2);
}

function updateQty(idx, val) {
    cart[idx].qty = parseInt(val) || 1;
    renderCart();
}

function removeItem(idx) {
    cart.splice(idx, 1);
    renderCart();
}

// Search Function
document.getElementById('productSearch').onkeyup = function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll('.product-item').forEach(item => {
        item.style.display = item.dataset.name.includes(val) ? 'block' : 'none';
    });
};

// Quick Add Customer Form Submission
document.getElementById('quickAddCustomerForm').onsubmit = async function(e) {
    e.preventDefault();
    
    // Get data from form
    const formData = new FormData(this);
    const data = Object.fromEntries(formData.entries());

    try {
        const res = await fetch('/customers/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        
        const result = await res.json();
        
        if (result.success) {
            // 1. Add the new customer to the existing dropdown list
            const customerSelect = document.getElementById('customerSelect');
            const newOption = new Option(`${result.customer.name} - ${result.customer.phone}`, result.customer.id);
            customerSelect.add(newOption);
            
            // 2. Automatically select this new customer
            customerSelect.value = result.customer.id;
            
            // 3. Close the modal and reset form
            const modalElement = document.getElementById('newCustomerModal');
            const modalInstance = bootstrap.Modal.getInstance(modalElement);
            modalInstance.hide();
            this.reset();
            
            showNotify("Customer added and selected!");
        } else {
            showNotify("Failed to add customer", "danger");
        }
    } catch (err) {
        console.error(err);
        showNotify("Server error while adding customer", "danger");
    }
};
</script>
<%- include('footer') %>