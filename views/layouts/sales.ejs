<%- include('header') %>

<div class="container-fluid">
    <div class="row">
    
    <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 bg-light" style="padding-top: 100px;">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Order Listing</h2>
            <a href="/pos" class="btn btn-primary">New Sale</a>
        </div>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Date</th>
                <th>Invoice No</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            <% orders.forEach(order => { %>
                <tr>
                    <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                    <td><strong><%= order.invoice_no %></strong></td>
                    <td>₹ <%= order.total %></td>
                    <td>
                        <span class="badge bg-success">Paid</span>
                    </td>
                    <td>
                        <a href="/invoice/<%= order.id %>" class="btn btn-sm btn-warning text-dark">
                            View / Print
                        </a>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    </main>
    </div>
</div>

<%- include('footer') %>