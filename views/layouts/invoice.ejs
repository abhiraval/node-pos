<!DOCTYPE html>
<html>
<head>
  <title>Invoice</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    @media print {
      .no-print { display: none; }
    }
  </style>
</head>

<body class="p-4">

<div class="container">

  <h2><%= user.Storename %></h2>
  <p>Date: <%= sale.created_at %></p>
  <p>Invoice No: <%= sale.invoice_no %></p>

  <hr>

  <table class="table table-bordered">
    <thead>
      <tr>
        <th>Product</th>
        <th>Qty</th>
        <th>Price</th>
        <th>Total</th>
      </tr>
    </thead>

    <tbody>
      <% items.forEach(item => { %>
        <tr>
          <td><%= item.name %></td>
          <td><%= item.quantity %></td>
          <td>₹ <%= item.price %></td>
          <td>₹ <%= item.price * item.quantity %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <h4 class="text-end">Total: ₹ <%= sale.total %></h4>

  <div class="no-print mt-3">
    <button onclick="window.print()" class="btn btn-primary">Print</button>
    <a href="/pos" class="btn btn-secondary">Back</a>
  </div>

</div>

</body>
</html>