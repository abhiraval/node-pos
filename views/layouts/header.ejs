<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

  <style>
    body {
      margin: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #f5f6fa;
    }

    /* Sidebar */
    .sidebar {
      width: 240px;
      height: 100vh;
      background: #1f2937;
      color: #fff;
      position: fixed;
      top: 0;
      left: 0;
      display: flex;
      flex-direction: column;
    }

    .sidebar .brand {
      font-size: 20px;
      font-weight: bold;
      padding: 20px;
      text-align: center;
      border-bottom: 1px solid #374151;
    }

    .sidebar .user-info {
      padding: 15px;
      font-size: 14px;
      border-bottom: 1px solid #374151;
      text-align: center;
      color: #9ca3af;
    }

    .sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
      flex: 1;
    }

    .sidebar li {
      margin: 5px 0;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      color: #d1d5db;
      text-decoration: none;
      transition: 0.3s;
      border-radius: 6px;
      margin: 0 10px;
    }

    .sidebar a:hover {
      background: #374151;
      color: #fff;
    }

    .sidebar a.active {
      background: #4f46e5;
      color: #fff;
    }

    /* Topbar */
    .topbar {
      position: fixed;
      left: 240px;
      right: 0;
      top: 0;
      height: 60px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.05);
      z-index: 1000;
    }

    .topbar .title {
      font-weight: 600;
    }

    /* Content */
    .content {
      margin-left: 240px;
      margin-top: 60px;
      padding: 20px;
    }
  </style>
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">

  <div class="brand">🧾 POS System</div>

  <div class="user-info">
    <div><strong><%= user.username %></strong></div>
    <small><%= user.Storename %></small>
  </div>

<ul>
  <li>
    <a href="/dashboard" class="menu-link <%= (active === 'dashboard') ? 'active' : '' %>">
      <i class="bi bi-speedometer2"></i> Dashboard
    </a>
  </li>

  <% if (user.role === 'admin') { %>
    <li>
      <a href="/inventory" class="menu-link <%= (active === 'inventory') ? 'active' : '' %>">
        <i class="bi bi-box-seam"></i> Inventory
      </a>
    </li>
  <% } %>

  <li>
    <a href="/pos" class="menu-link <%= (active === 'pos') ? 'active' : '' %>">
      <i class="bi bi-calculator"></i> Billing / POS
    </a>
  </li>

  <% if (user.role === 'admin') { %>
    <li>
      <a href="/vendors" class="menu-link <%= (active === 'vendors') ? 'active' : '' %>">
        <i class="bi bi-truck"></i> Vendors
      </a>
    </li>
  <% } %>

  <li>
    <a href="/sales" class="menu-link <%= (active === 'sales') ? 'active' : '' %>">
      <i class="bi bi-receipt"></i> Orders
    </a>
  </li>
  <% if (user.role === 'admin') { %>
  <li>
    <a href="/users" class="menu-link <%= (active === 'users') ? 'active' : '' %>">
      <i class="bi bi-people"></i> Manage Users
    </a>
  </li>
<% } %>
<% if (user.role === 'admin') { %>
  <li>
    <a href="/ledger-list" class="menu-link <%= (active === 'ledger') ? 'active' : '' %>">
      <i class="bi bi-journal-text"></i> Ledger Accounts
    </a>
  </li>
<% } %>
<!-- <% if (user.role === 'admin') { %>
  <li>
    <a href="/purchases" class="menu-link <%= (active === 'purchases') ? 'active' : '' %>">
      <i class="bi bi-cart-plus"></i> Purchases
    </a>
  </li>
<% } %> -->
</ul>

</div>

<!-- Topbar -->
<div class="topbar">
  <div class="title">Welcome, <%= user.username %></div>

  <div>
    <a href="/logout" class="btn btn-outline-danger btn-sm">
      <i class="bi bi-box-arrow-right"></i> Logout
    </a>
  </div>
</div>